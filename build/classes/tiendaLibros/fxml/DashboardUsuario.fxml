<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox style="-fx-background-color: #1a1a2e;"
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="tiendaLibros.vista.UsuarioController">

    <!-- HEADER -->
    <HBox alignment="CENTER_LEFT" spacing="10"
          style="-fx-background-color: #16213e; -fx-padding: 15;">
        <Label text="📚" style="-fx-font-size: 22px;"/>
        <Label fx:id="lblBienvenida"
               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #e94560;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="lblCarritoCount" text="🛒 0 items"
               style="-fx-text-fill: #a8a8b3; -fx-font-size: 13px;"/>
        <Button text="Cerrar Sesión" onAction="#handleCerrarSesion"
                style="-fx-background-color: #e94560; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6;"/>
    </HBox>

    <TabPane tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS"
             style="-fx-background-color: #1a1a2e; -fx-tab-min-width: 160;">

        <!-- TAB CATÁLOGO CON TARJETAS -->
        <Tab text="🏪 Tienda">
            <VBox spacing="10" style="-fx-background-color: #1a1a2e;">
                <padding><Insets top="15" right="15" bottom="15" left="15"/></padding>
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="Buscar:" style="-fx-text-fill: #e2e2e2;"/>
                    <TextField fx:id="txtBuscar" promptText="Buscar libro..."
                               prefWidth="250"
                               style="-fx-background-color: #0f3460; -fx-text-fill: white; -fx-background-radius: 6;"/>
                    <Button text="🔍 Buscar" onAction="#handleBuscar"
                            style="-fx-background-color: #0f3460; -fx-text-fill: white; -fx-background-radius: 6;"/>
                    <Button text="Mostrar todos" onAction="#handleMostrarTodos"
                            style="-fx-background-color: #0f3460; -fx-text-fill: #a8a8b3; -fx-background-radius: 6;"/>
                </HBox>
                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                            style="-fx-background: #1a1a2e; -fx-background-color: #1a1a2e;">
                    <FlowPane fx:id="flowCatalogo" hgap="15" vgap="15" prefWrapLength="900"
                              style="-fx-background-color: #1a1a2e; -fx-padding: 5;"/>
                </ScrollPane>
            </VBox>
        </Tab>

        <!-- TAB CARRITO -->
        <Tab text="🛒 Carrito (Pila)">
            <VBox spacing="10" style="-fx-background-color: #1a1a2e;">
                <padding><Insets top="15" right="15" bottom="15" left="15"/></padding>
                <Label text="PILA LIFO — el último libro agregado es el primero en quitarse"
                       style="-fx-font-size: 11px; -fx-text-fill: #a8a8b3; -fx-font-style: italic;"/>
                <TableView fx:id="tablaCarrito" VBox.vgrow="ALWAYS"
                           style="-fx-background-color: #16213e;">
                    <columns>
                        <TableColumn fx:id="colCarritoTitulo"    text="Libro"       prefWidth="280"/>
                        <TableColumn fx:id="colCarritoCantidad"  text="Cantidad"    prefWidth="90"/>
                        <TableColumn fx:id="colCarritoSubtotal"  text="Subtotal"    prefWidth="110"/>
                    </columns>
                </TableView>
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label fx:id="lblTotal" text="Total: $0"
                           style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #e94560;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="↩️ Quitar Último" onAction="#handleQuitarUltimo"
                            style="-fx-background-color: #e67e22; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6;"/>
                    <Button text="✅ Confirmar Compra" onAction="#handleConfirmarCompra"
                            style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6;"/>
                </HBox>
                <Label fx:id="lblMsgCarrito" style="-fx-font-size: 12px; -fx-text-fill: white;"/>
            </VBox>
        </Tab>

        <!-- TAB LISTA DE DESEOS -->
        <Tab text="❤️ Lista de Deseos">
            <VBox spacing="10" style="-fx-background-color: #1a1a2e;">
                <padding><Insets top="15" right="15" bottom="15" left="15"/></padding>
                <Label text="LISTA ENLAZADA SENCILLA — libros guardados para comprar después"
                       style="-fx-font-size: 11px; -fx-text-fill: #a8a8b3; -fx-font-style: italic;"/>
                <TableView fx:id="tablaDeseos" VBox.vgrow="ALWAYS"
                           style="-fx-background-color: #16213e;">
                    <columns>
                        <TableColumn fx:id="colDeseosTitulo"  text="Título"      prefWidth="260"/>
                        <TableColumn fx:id="colDeseosAutor"   text="Autor"       prefWidth="160"/>
                        <TableColumn fx:id="colDeseosPrecio"  text="Precio"      prefWidth="100"/>
                    </columns>
                </TableView>
                <HBox spacing="10">
                    <Button text="🗑️ Eliminar de Deseos" onAction="#handleEliminarDeseo"
                            style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6;"/>
                    <Button text="🛒 Mover al Carrito" onAction="#handleMoverAlCarrito"
                            style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6;"/>
                </HBox>
                <Label fx:id="lblMsgDeseos" style="-fx-font-size: 12px; -fx-text-fill: white;"/>
            </VBox>
        </Tab>

        <!-- TAB HISTORIAL -->
        <Tab text="📜 Mis Compras">
            <VBox spacing="10" style="-fx-background-color: #1a1a2e;">
                <padding><Insets top="15" right="15" bottom="15" left="15"/></padding>
                <Label text="COLA FIFO — primera compra = primera en mostrarse"
                       style="-fx-font-size: 11px; -fx-text-fill: #a8a8b3; -fx-font-style: italic;"/>
                <TableView fx:id="tablaHistorial" VBox.vgrow="ALWAYS"
                           style="-fx-background-color: #16213e;">
                    <columns>
                        <TableColumn fx:id="colHistFecha"   text="Fecha"    prefWidth="130"/>
                        <TableColumn fx:id="colHistDetalle" text="Detalle"  prefWidth="430"/>
                        <TableColumn fx:id="colHistTotal"   text="Total"    prefWidth="100"/>
                    </columns>
                </TableView>
                <Button text="🔄 Refrescar" onAction="#handleRefrescarHistorial"
                        style="-fx-background-color: #2980b9; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6;"/>
            </VBox>
        </Tab>

    </TabPane>
</VBox>
